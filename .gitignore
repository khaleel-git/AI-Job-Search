# Ignore everything by default
*

# Allow directory traversal so allowlist patterns can work
!*/

# Keep source/docs and gitignore tracked
!*.py
!*.md
!.gitignore
!**/requirements.txt

# Explicitly ignore sensitive/config/token files
*.csv
*.json
token.json
credentials.json
.env
.env.*
*.env

# Ignore environment folders/data
venv/
env/
.venv/

# Ignore Chrome profile/session data
chrome_linkedin_profile/
**/chrome_linkedin_profile/

# Python cache artifacts
__pycache__/
*.py[cod]

# Common system/IDE noise
.DS_Store
Thumbs.db
.vscode/
.idea/
